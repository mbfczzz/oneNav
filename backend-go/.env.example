# Backend (Go) config — copy to backend-go/.env (gitignored) and fill in.
# Real environment variables always win over this file.
# DB_PASSWORD is REQUIRED; the server refuses to start without it.

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=zmark
DB_USERNAME=root
DB_PASSWORD=
TABLE_PREFIX=onenav_
PORT=8787
ADMIN_USER=admin
ADMIN_PASS=admin123
# session lifetime in hours (default 168 = 7 days)
AUTH_TTL_HOURS=168
# Serve the built SPA (dist) from this same server/port — single-process deploy,
# no Nginx needed. The one-click deploy.sh sets this automatically.
# WEB_DIR=/opt/oneNav/dist
